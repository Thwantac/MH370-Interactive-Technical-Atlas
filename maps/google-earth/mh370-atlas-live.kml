<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>MH370 Interactive Technical Atlas — Live Link</name>
  <description><![CDATA[
    This file links Google Earth to the current master MH370 atlas KML hosted on GitHub.

    If the master atlas file is updated on GitHub, Google Earth can refresh this network link
    to retrieve the latest available version.

    This is a work-in-progress visual aid, not a final reconstruction.
  ]]></description>

  <NetworkLink>
    <name>MH370 Interactive Technical Atlas — Master Layer</name>
    <open>1</open>
    <visibility>1</visibility>
    <refreshVisibility>1</refreshVisibility>
    <Link>
      <href>https://raw.githubusercontent.com/Thwantac/MH370-Interactive-Technical-Atlas/main/maps/google-earth/mh370-atlas-master.kml</href>
      <refreshMode>onInterval</refreshMode>
      <refreshInterval>3600</refreshInterval>
    </Link>
  </NetworkLink>
</Document>
</kml>