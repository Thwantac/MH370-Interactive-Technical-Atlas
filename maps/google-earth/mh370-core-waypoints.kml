  <name>MH370 Core Waypoints</name>
  <description>Official waypoint coordinates from the MH370 Interactive Technical Atlas.</description>
  <Folder>
    <name>Official waypoint coordinates</name>
    <Placemark>
      <name>VENLI</name>
      <description><![CDATA[
        <b>Source:</b> SRC-0001<br/>
        <b>Confidence:</b> high<br/>
        <b>Notes:</b> Official report lists VENLI coordinate as 062846N 1024900E; route M765 between VENLI and IGARI.
      ]]></description>
      <Point>
        <coordinates>102.816667,6.479444,0</coordinates>
      </Point>
    </Placemark>
    <Placemark>
      <name>IGARI</name>
